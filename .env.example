# KINTUNNEL deployment environment.
# Copy to .env and edit before starting Compose.

COMPOSE_PROJECT_NAME=kintunnel
TZ=UTC
KINTUNNEL_ENV=production

# Compose builds local images by default when these are unset.
# Set these only when you want to retag local builds or use release images.
# KINTUNNEL_ENGINE_IMAGE=ghcr.io/OWNER/kintunnel-engine:v0.1.0
# KINTUNNEL_ADMIN_IMAGE=ghcr.io/OWNER/kintunnel-admin:v0.1.0

# Public endpoint used in generated WireGuard client configs.
# Use a DNS name where possible.
KINTUNNEL_PUBLIC_ENDPOINT=vpn.example.com
KINTUNNEL_DRY_RUN=true
KINTUNNEL_WG_PORT=51820
KINTUNNEL_WG_INTERFACE=wg0
KINTUNNEL_WG_ADDRESS=10.44.0.1/24
KINTUNNEL_WG_DNS=1.1.1.1
KINTUNNEL_ALLOWED_IPS=0.0.0.0/0

# Admin UI is bound to localhost by default for safety.
# Put a real HTTPS reverse proxy in front of it before remote access.
KINTUNNEL_ADMIN_BIND_HOST=127.0.0.1
KINTUNNEL_ADMIN_PORT=8080

# Admin authentication. Create this file locally; do not commit real secrets.
# Example:
#   mkdir -p config/secrets
#   openssl rand -base64 32 > config/secrets/admin-token.txt
#   openssl rand -base64 32 > config/secrets/engine-api-token.txt
# Alternatively set KINTUNNEL_ADMIN_TOKEN directly for throwaway local runs.
KINTUNNEL_ADMIN_TOKEN_FILE=./config/secrets/admin-token.txt
# KINTUNNEL_ADMIN_TOKEN=change-me-local-only

# Engine API authentication between the admin UI and engine.
KINTUNNEL_ENGINE_API_TOKEN_FILE=./config/secrets/engine-api-token.txt
# KINTUNNEL_ENGINE_API_TOKEN=change-me-local-only

# Script defaults.
KINTUNNEL_CLIENT_REQUEST_DIR=./tmp/client-requests

# Networking policy: set to true to apply MASQUERADE + FORWARD rules via iptables.
# Set to false if your platform handles NAT externally (Dokploy, host firewall, etc).
KINTUNNEL_NAT_APPLY=true

# Backup storage directory. Must be on the same filesystem as KINTUNNEL_DATA_DIR.
KINTUNNEL_BACKUP_DIR=/backups

# Retention: number of snapshots to keep. Older snapshots are pruned on each create.
KINTUNNEL_BACKUP_RETENTION_COUNT=7

# Backup lock timeout in milliseconds. Backs off rather than spinning.
KINTUNNEL_BACKUP_LOCK_TIMEOUT_MS=5000

# Log level. One of: debug, info, warn, error, silent.
KINTUNNEL_LOG_LEVEL=info
